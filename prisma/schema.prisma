generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PriceHistory {
  id          Int       @id @default(autoincrement())
  currency    String    @db.VarChar(10)
  rate        Decimal   @db.Decimal(20, 10)
  source      String    @db.VarChar(100)
  timestamp   DateTime  @db.Timestamp(3)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  currencyRef Currency? @relation(fields: [currency], references: [code])

  @@index([currency, timestamp])
  @@index([timestamp])
  @@unique([currency, source, timestamp])
}

model Currency {
  code         String         @id @db.VarChar(10)
  name         String         @db.VarChar(100)
  symbol       String         @db.VarChar(5)
  decimals     Int            @default(2)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  priceHistory PriceHistory[]
}

model PriceRecord {
  id        Int      @id @default(autoincrement())
  currency  String
  value     Float
  timestamp DateTime
}

model ProviderReputation {
  id                    Int       @id @default(autoincrement())
  providerName          String    @db.VarChar(100)
  endpoint              String    @default("") @db.VarChar(255)
  status                String    @db.VarChar(20)
  totalRequests         Int       @default(0)
  successfulRequests    Int       @default(0)
  failedRequests        Int       @default(0)
  incorrectResponses    Int       @default(0)
  averageLatency        Float?
  lastSuccess           DateTime?
  lastFailure           DateTime?
  lastIncorrect         DateTime?
  consecutiveFailures   Int       @default(0)
  consecutiveIncorrect  Int       @default(0)
  reliabilityScore      Float?
  lastUpdated           DateTime  @updatedAt
  createdAt             DateTime  @default(now())

  @@index([providerName])
  @@index([status])
  @@index([reliabilityScore])
  @@unique([providerName, endpoint])
}
